# ═══════════════════════════════════════════════════════════
# AlexSync payment (Cashfree) + Supabase — set these as real
# Environment Variables on Render. Never commit actual values.
# ═══════════════════════════════════════════════════════════

# From Cashfree Merchant Dashboard → Developers → API Keys
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=

# "SANDBOX" while testing, "PRODUCTION" once you go live
CASHFREE_ENV=SANDBOX

# Cashfree Dashboard → Developers → Webhooks → set this same value there
CASHFREE_WEBHOOK_SECRET=

# Your live site URL (used to build the Cashfree return_url)
PUBLIC_BASE_URL=https://alexcyber.onrender.com

# Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AlexTrace needs no extra env vars — every check it runs (username
# enumeration, Gravatar, free HIBP breach list, EXIF metadata) is
# free and keyless.
